# OfficeRnD Flex API Explorer — server config
# Copy to swagger/.env, OR rely on the project-root .env (auto-loaded as fallback).
#
# Everything here is OPTIONAL. Any value set below pre-fills the matching field in
# Swagger UI's "Authorize" dialog (still editable in the browser); anything left
# blank you simply type into the dialog. The token is always minted in the
# browser — the server never uses these to authenticate on your behalf.

# OFFICERND_ORG_SLUG=your-org-slug
# OFFICERND_CLIENT_ID=your-client-id
# OFFICERND_CLIENT_SECRET=your-client-secret

# Port for the local UI (default 8088)
PORT=8088
