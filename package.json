{
  "name": "avila-scrapper",
  "version": "0.1.0",
  "private": true,
  "description": "Daily backup/sync of OfficeRnD Flex data into a local SQLite DB + git-committed JSON snapshots.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "bin": {
    "avila": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx src/cli.ts",
    "sync": "tsx src/cli.ts sync",
    "sync:full": "tsx src/cli.ts sync --full",
    "export": "tsx src/cli.ts export",
    "backup": "tsx src/cli.ts backup",
    "restore": "tsx src/cli.ts restore",
    "schedule": "tsx src/scheduler.ts"
  },
  "dependencies": {
    "commander": "^13.1.0",
    "dotenv": "^16.4.7",
    "node-cron": "^3.0.3",
    "postgres": "^3.4.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.1",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "packageManager": "pnpm@10.19.0+sha512.c9fc7236e92adf5c8af42fd5bf1612df99c2ceb62f27047032f4720b33f8eacdde311865e91c411f2774f618d82f320808ecb51718bfa82c060c4ba7c76a32b8"
}
