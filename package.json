{
  "name": "avila-scrapper",
  "version": "0.1.0",
  "private": true,
  "description": "Daily backup/sync of OfficeRnD Flex data into a local SQLite DB + git-committed JSON snapshots.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["better-sqlite3", "esbuild"]
  },
  "bin": {
    "avila": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx src/cli.ts",
    "sync": "tsx src/cli.ts sync",
    "sync:full": "tsx src/cli.ts sync --full",
    "export": "tsx src/cli.ts export",
    "backup": "tsx src/cli.ts backup",
    "restore": "tsx src/cli.ts restore",
    "schedule": "tsx src/scheduler.ts"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "commander": "^13.1.0",
    "dotenv": "^16.4.7",
    "node-cron": "^3.0.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.13.1",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
