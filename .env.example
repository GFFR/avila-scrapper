# OfficeRnD Flex API v2 credentials
# Create an application in: Settings > Data & Extensibility > Developer Tools (Read-only is enough)
OFFICERND_CLIENT_ID=
OFFICERND_CLIENT_SECRET=
# Your organization slug (the {org} part of app.officernd.com/{org}/...)
OFFICERND_ORG_SLUG=

# Optional: space-separated OAuth scopes to request. Leave empty to receive the
# scopes granted to your application. If list calls 403, set explicit read scopes,
# e.g.: "flex.community.members.read flex.billing.payments.read ..."
OFFICERND_SCOPES=

# Where data lives. data/json is committed; the sqlite file is on a volume/local only.
DATA_DIR=./data

# Daily sync schedule (cron syntax, used by `pnpm schedule`). Default 03:15 every day.
SYNC_CRON=15 3 * * *
# IANA timezone for the cron schedule
SYNC_TZ=Europe/Lisbon

# Set to "true" to have the scheduler git-commit & push JSON snapshots after each sync.
# Requires a git identity and a write-enabled deploy key in the container.
AUTO_GIT_COMMIT=false
