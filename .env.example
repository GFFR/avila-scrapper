# OfficeRnD Flex API v2 credentials
# Create an application in: Settings > Data & Extensibility > Developer Tools (Read-only is enough)
OFFICERND_CLIENT_ID=
OFFICERND_CLIENT_SECRET=
# Your organization slug (the {org} part of app.officernd.com/{org}/...)
OFFICERND_ORG_SLUG=

# Optional override of OAuth scopes (space-separated). Leave empty to use the
# scopes derived automatically from the resource registry (recommended).
# OfficeRnD rejects the whole token if any requested scope isn't granted.
OFFICERND_SCOPES=

# Postgres connection string (the live queryable store).
# Local docker-compose: postgres://avila:avila@localhost:5432/avila
# Dokploy: use the internal connection string of the provisioned Postgres service.
DATABASE_URL=postgres://avila:avila@localhost:5432/avila
# Set true if your Postgres requires TLS (most managed providers do).
DB_SSL=false

# Where JSON snapshots are written (committed to git as the portable backup).
DATA_DIR=./data

# Daily incremental sync schedule (cron syntax, used by `pnpm schedule`).
SYNC_CRON=15 3 * * *
# Weekly full reconciliation (re-pulls everything, incl. full fan-outs) so
# incremental fan-outs catch changes that didn't bump a parent's modifiedAt.
SYNC_FULL_CRON=0 4 * * 0
# IANA timezone for the cron schedules
SYNC_TZ=Europe/Lisbon

# Set to "true" to have the scheduler git-commit & push JSON snapshots after each sync.
# Requires a git identity and a write-enabled deploy key in the container.
AUTO_GIT_COMMIT=false
